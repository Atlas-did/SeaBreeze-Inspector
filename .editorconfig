# =============================================================================
# EditorConfig — 统一编辑器配置
# 重要提醒：本项目使用YAML作为配置格式，缩进必须用空格，绝对不能用Tab
# =============================================================================

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# YAML配置文件：缩进2个空格
[*.{yaml,yml}]
indent_style = space
indent_size = 2

# Python代码：缩进4个空格
[*.py]
indent_style = space
indent_size = 4

# Shell脚本
[*.{sh,bat}]
indent_style = space
indent_size = 4

# Markdown文档
[*.md]
trim_trailing_whitespace = false
